# TalentIQ — Environment Variables
# Copy this file to .env and fill in your keys

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — enables Twitter reputation checks
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Optional — enables richer company growth data
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here

# Optional — PostgreSQL (defaults to in-memory if not set)
DATABASE_URL=postgresql://user:password@localhost:5432/talentiq

# App settings
PORT=8000
ENVIRONMENT=development
