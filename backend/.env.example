# TalentIQ Backend — Environment Variables
# Copy to .env and fill in your keys

# Required — powers cover letters, roadmaps, mock interview
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Your deployed Vercel frontend URL (for CORS)
FRONTEND_URL=https://talentiq.vercel.app

# Optional — enables Twitter/X reputation checks
TWITTER_BEARER_TOKEN=

# Optional — richer company growth data
CRUNCHBASE_API_KEY=

# App
PORT=8000
ENVIRONMENT=development
